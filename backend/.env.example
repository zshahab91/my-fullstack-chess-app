# OpenAI OIDC / OAuth settings
OPENAI_CLIENT_ID=your_openai_client_id
OPENAI_CLIENT_SECRET=your_openai_client_secret
OPENAI_REDIRECT_URI=http://localhost:3000/api/user/oidc-callback
OPENAI_ISSUER=https://auth.openai.com

# Application JWT secret (change in production)
APP_JWT_SECRET=change_me_to_a_strong_secret

# Cookie signing secret for state storage
APP_COOKIE_SECRET=change_me_cookie_secret

# App settings
PORT=3500
NODE_ENV=development
